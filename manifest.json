{
  "manifest_version": 3,
  "name": "Goodreads Edition Language Checker",
  "version": "4.4.0",
  "description": "Checks on demand for editions in a selected language and discreetly marks book covers on Goodreads.",
  "homepage_url": "https://github.com/rapinoinfeliz/goodreads-language-checker",

  "permissions": [
    "storage"
  ],

  "content_scripts": [
    {
      "matches": ["https://www.goodreads.com/*"],
      "js": ["shared.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Choose edition language"
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
